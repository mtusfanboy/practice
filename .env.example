# Пример файла переменных окружения (DO-04).
# Скопируйте в `.env` и при необходимости измените значения:
#   cp .env.example .env
# Файл `.env` НЕ должен попадать в репозиторий (см. .gitignore).

# --- Общие настройки приложения ---
APP_NAME=University Knowledge Search
ENVIRONMENT=production
DEBUG=false
# Разрешённые источники для CORS (через запятую).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Порты, публикуемые на хосте ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# --- PostgreSQL ---
POSTGRES_DB=knowledge_base
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_postgres

# --- Elasticsearch ---
ELASTICSEARCH_INDEX=documents
# Память JVM для Elasticsearch (увеличьте при больших объёмах данных).
ES_JAVA_OPTS=-Xms512m -Xmx512m

# --- Redis / кеш ---
# Время жизни кеша поисковых запросов в секундах (BE-10: 300 = 5 минут).
CACHE_TTL_SECONDS=300

# --- Загрузка документов ---
# Максимальный размер файла в байтах (BE-02: 20 МБ).
MAX_UPLOAD_SIZE_BYTES=20971520

# --- Grafana (мониторинг) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana
