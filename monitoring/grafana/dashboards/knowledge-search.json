{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "title": "Knowledge Search — Overview",
  "uid": "knowledge-search",
  "tags": ["knowledge-search"],
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Поисковых запросов всего",
      "description": "Суммарное число запросов к /api/v1/search (DO-06).",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(search_requests_total)", "refId": "A", "legendFormat": "всего" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Среднее время ответа поиска",
      "description": "Среднее время обработки поискового запроса (DO-06).",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(search_latency_seconds_sum[5m])) / clamp_min(sum(rate(search_latency_seconds_count[5m])), 0.0001)",
          "refId": "A",
          "legendFormat": "среднее"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 4, "color": { "mode": "thresholds" } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Запросы поиска в секунду (по источнику)",
      "description": "Частота запросов к поиску с разбивкой на кеш/Elasticsearch.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (source) (rate(search_requests_total[1m]))", "refId": "A", "legendFormat": "{{source}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Время ответа поиска (avg / p95)",
      "description": "Среднее и 95-й перцентиль времени выполнения поиска.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(search_latency_seconds_sum[5m])) / clamp_min(sum(rate(search_latency_seconds_count[5m])), 0.0001)",
          "refId": "A",
          "legendFormat": "среднее"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(search_latency_seconds_bucket[5m])) by (le))",
          "refId": "B",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Загруженные документы (по статусу)",
      "description": "Накопленное число документов по итоговому статусу обработки.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (status) (documents_uploaded_total)", "refId": "A", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "HTTP-запросы в секунду (все эндпоинты)",
      "description": "Общая частота HTTP-запросов к бэкенду (prometheus-fastapi-instrumentator).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (handler) (rate(http_requests_total[1m]))", "refId": "A", "legendFormat": "{{handler}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      }
    ]
  }
}
